{
  "name": "pixi-solid-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r run test",
    "preinstall": "npx only-allow pnpm",
    "lint": "oxlint",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "jsdom": "28.0.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "sass-embedded": "1.99.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "overrides": {
      "pixi.js": "8.18.1",
      "solid-js": "1.9.12"
    }
  }
}
