{
  "name": "pixi-solid",
  "version": "1.0.0-rc.15",
  "private": false,
  "description": "A library to write PixiJS applications with SolidJS",
  "homepage": "https://lukecarlthompson.github.io/pixi-solid/",
  "license": "MIT",
  "author": "Luke Thompson",
  "repository": {
    "type": "git",
    "url": "https://github.com/LukeCarlThompson/pixi-solid"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "pixi-solid-logo.png"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "browser": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "browser": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./testing": {
      "browser": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "rm -rf dist",
    "build": "vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "prepublishOnly": "pnpm run build",
    "prepack": "node -e \"require('fs').existsSync('dist/index.js') || (console.error('ERROR: dist/index.js not found') && process.exit(1))\"",
    "postbuild": "pnpm copy:skill",
    "copy:skill": "[ -d src/skill ] && cp -r src/skill dist/skill || (echo \"ERROR: src/skill directory not found\" >&2 && exit 1)",
    "preview": "vite preview",
    "preinstall": "npx only-allow pnpm",
    "test": "vitest --run",
    "test:bench": "vitest bench",
    "test:bench:save": "vitest bench --outputJson=src/benchmarks/results/baseline.json",
    "test:bench:compare": "vitest bench --compare=src/benchmarks/results/baseline.json",
    "typecheck": "tsc --project tsconfig.test.json --noEmit"
  },
  "peerDependencies": {
    "pixi.js": ">=8.14.3 <9",
    "solid-js": ">=1.9.10 <2"
  }
}
