{
  "extends": "../../tsconfig.json",
  "include": ["./src/**/*"],
  "exclude": [
    "src/demo/**/*",
    "src/benchmarks/**/*",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "compilerOptions": {
    "target": "es2022",
    "declaration": true,
    "declarationDir": "./dist",
    "sourceMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src"
  }
}
